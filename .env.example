# ==================== SERVER CONFIGURATION ====================
PORT=3000
NODE_ENV=production
APP_URL=https://your-app.railway.app

# ==================== DATABASE ====================
DATABASE_URL=postgresql://user:password@host:5432/swiftpay

# ==================== AUTHENTICATION ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==================== STRIPE PAYMENT GATEWAY ====================
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==================== PAYPAL PAYMENT GATEWAY ====================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox
# For production, change to: PAYPAL_MODE=live

# ==================== MTN MOBILE MONEY ====================
MTN_API_KEY=your-mtn-api-key
MTN_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_API_USER=your-mtn-api-user
MTN_API_SECRET=your-mtn-api-secret
MTN_ENVIRONMENT=sandbox
# For production, change to: MTN_ENVIRONMENT=production

# ==================== FLUTTERWAVE ====================
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TEST...

# ==================== PAYSTACK ====================
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_SECRET_KEY=sk_test_...

# ==================== CRYPTOCURRENCY (Bitcoin/Ethereum) ====================
# For production, use proper crypto wallet API services like:
# - BlockCypher, Coinbase Commerce, BitPay, or BTCPay Server
CRYPTO_API_KEY=your-crypto-api-key
CRYPTO_WEBHOOK_SECRET=your-crypto-webhook-secret
BTC_NETWORK=testnet
# For production, change to: BTC_NETWORK=mainnet
ETH_NETWORK=goerli
# For production, change to: ETH_NETWORK=mainnet

# ==================== ADDITIONAL PAYMENT GATEWAYS ====================
# Add more as needed:
# SQUARE_ACCESS_TOKEN=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# BRAINTREE_MERCHANT_ID=
# BRAINTREE_PUBLIC_KEY=
# BRAINTREE_PRIVATE_KEY=

# ==================== SECURITY & RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== EMAIL NOTIFICATIONS (Optional) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ==================== LOGGING & MONITORING (Optional) ====================
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn
